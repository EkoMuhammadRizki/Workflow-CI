name: SMSML_Eko_Muhammad_Rizki

conda_env: conda.yaml

entry_points:
  train:
    parameters:
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
    command: "python modelling.py --n_estimators {n_estimators} --max_depth {max_depth}"

  main:
    command: "python modelling.py"
